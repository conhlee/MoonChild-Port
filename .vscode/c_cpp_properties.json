{
    "env": {
        "defaultIncludePaths": [
            "${workspaceFolder}/platform/**",
            "${workspaceFolder}/source/**",
            "${workspaceFolder}/source/framewrk/**",
            "${workspaceFolder}/source/moonchild/**"
        ],
        "defaultDefines": [],
        "rvlIncludePaths": [
            "C:/devkitPro/portlibs/ppc/include/**",
            "C:/devkitPro/portlibs/wii/include/**",
            "C:/devkitPro/libogc/include/**"
        ],
        "rvlDefines": [
            "HW_RVL",
            "PLATFORM_WII"
        ],
        "dolIncludePaths": [
            "C:/devkitPro/portlibs/ppc/include/**",
            "C:/devkitPro/portlibs/gamecube/include/**",
            "C:/devkitPro/libogc/include/**"
        ],
        "dolDefines": [
            "HW_DOL",
            "PLATFORM_WII"
        ],
        "sdlIncludePaths": [
            "C:/msys64/ucrt64/include",
            "C:/msys64/ucrt64/include/SDL2"
        ],
        "sdlDefines": [
        ],
        "ppcCompilerPath": "C:/devkitPro/devkitPPC/bin/powerpc-eabi-g++",
        "winCompilerPath": "C:/msys64/ucrt64/bin/gcc"
    },
    "configurations": [
        {
            "name": "SDL",
            "includePath": [
                "${env:defaultIncludePaths}",
                "${env:sdlIncludePaths}"
            ],
            "defines": [
                "${env:defaultDefines}",
                "${env:sdlDefines}"
            ],
            "compilerPath": "${env:winCompilerPath}",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64"
        },
        {
            "name": "Wii",
            "includePath": [
                "${env:defaultIncludePaths}",
                "${env:rvlIncludePaths}"
            ],
            "defines": [
                "${env:defaultDefines}",
                "${env:rvlDefines}"
            ],
            "compilerPath": "${env:ppcCompilerPath}",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-arm"
        }
    ],
    "version": 4
}